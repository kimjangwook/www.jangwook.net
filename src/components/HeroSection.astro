---
import { useTranslations, type Language } from '../lib/i18n/languages';

interface Props {
	lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const copy = {
	ko: {
		kicker: 'now writing — daily lab notes',
		titleA: '안녕하세요,',
		titleB: '김장욱입니다.',
		subtitle: 'AI 에이전트, 자동화 도구, 개발 실험을 샌드박스에서 검증하고 기록하는 개인 기술 노트입니다.',
		primary: '최신 글 읽기',
		secondary: '소개 보기',
		stats: [
			['daily', 'cadence'],
			['4', 'languages'],
			['lab', 'sandbox first'],
			['jw', 'personal notes'],
		],
	},
	ja: {
		kicker: 'now writing — daily lab notes',
		titleA: 'こんにちは、',
		titleB: 'Kim Jangwookです。',
		subtitle: 'AIエージェント、自動化ツール、開発実験をサンドボックスで検証して記録する個人技術ノートです。',
		primary: '最新記事を読む',
		secondary: '紹介を見る',
		stats: [
			['daily', 'cadence'],
			['4', 'languages'],
			['lab', 'sandbox first'],
			['jw', 'personal notes'],
		],
	},
	en: {
		kicker: 'now writing — daily lab notes',
		titleA: "Hi, I'm",
		titleB: 'Jangwook.',
		subtitle: t('site.description'),
		primary: 'Read latest',
		secondary: 'About',
		stats: [
			['daily', 'cadence'],
			['4', 'languages'],
			['lab', 'sandbox first'],
			['jw', 'personal notes'],
		],
	},
	zh: {
		kicker: 'now writing — daily lab notes',
		titleA: '你好，',
		titleB: '我是 Kim Jangwook。',
		subtitle: '这是我的个人技术笔记，记录 AI 代理、自动化工具和软件实验的验证过程。',
		primary: '阅读最新文章',
		secondary: '关于我',
		stats: [
			['daily', 'cadence'],
			['4', 'languages'],
			['lab', 'sandbox first'],
			['jw', 'personal notes'],
		],
	},
}[lang];
---

<section class="home-hero">
	<div class="home-hero__rail" aria-hidden="true">
		<span>JANGWOOK.NET · FIELD NOTEBOOK</span>
		<i></i>
		<i></i>
		<i></i>
	</div>

	<div class="home-hero__content">
		<div class="home-hero__main">
			<div class="home-hero__kicker mono uc">
				<span class="flow-dot"></span>
				{copy.kicker}
			</div>

			<h1>
				<span>{copy.titleA}</span>
				<em>{copy.titleB}</em>
			</h1>

			<p>{copy.subtitle}</p>

			<div class="home-hero__actions">
				<a class="home-hero__button home-hero__button--primary" href={`/${lang}/blog`}>
					{copy.primary}
				</a>
				<a class="home-hero__button home-hero__button--secondary" href={`/${lang}/about`}>
					{copy.secondary}
				</a>
			</div>
		</div>

		<aside class="home-hero__stats" aria-label="Site summary">
			<div class="mono uc">counts</div>
			{copy.stats.map(([value, label]) => (
				<div class="home-hero__stat">
					<strong>{value}</strong>
					<span class="mono">{label}</span>
				</div>
			))}
		</aside>
	</div>
</section>

<style>
	.home-hero {
		display: grid;
		grid-template-columns: 72px minmax(0, 1fr);
		background: var(--paper);
		border-bottom: 1px solid var(--paper-rule);
		overflow: hidden;
	}

	.home-hero__rail {
		position: relative;
		min-height: 38rem;
		border-right: 1px solid var(--paper-rule);
	}

	.home-hero__rail span {
		position: absolute;
		left: 1.45rem;
		top: 2rem;
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.22em;
		color: var(--ink-3);
	}

	.home-hero__rail i {
		position: absolute;
		right: -3px;
		width: 5px;
		height: 5px;
		border-radius: 999px;
		background: var(--ink-4);
	}

	.home-hero__rail i:nth-of-type(1) {
		top: 5rem;
	}

	.home-hero__rail i:nth-of-type(2) {
		top: 18rem;
		background: var(--flow);
	}

	.home-hero__rail i:nth-of-type(3) {
		top: 31rem;
	}

	.home-hero__content {
		width: min(1180px, 100%);
		margin: 0 auto;
		padding: clamp(3rem, 8vw, 6rem) 1.5rem clamp(3.5rem, 8vw, 6.5rem);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 18rem;
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: end;
	}

	.home-hero__main {
		max-width: 46rem;
	}

	.home-hero__kicker {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		margin-bottom: 1.2rem;
		font-size: 0.68rem;
		font-weight: 600;
		color: var(--flow-deep);
	}

	.home-hero h1 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: clamp(3.4rem, 8vw, 6.2rem);
		font-weight: 500;
		line-height: 0.98;
		letter-spacing: -0.03em;
		text-wrap: balance;
	}

	.home-hero h1 span,
	.home-hero h1 em {
		display: block;
	}

	.home-hero h1 em {
		color: var(--flow-deep);
		font-style: italic;
	}

	.home-hero p {
		margin: 1.55rem 0 0;
		max-width: 38rem;
		font-family: var(--font-serif);
		font-size: clamp(1.12rem, 2vw, 1.35rem);
		line-height: 1.55;
		color: var(--ink-2);
		text-wrap: pretty;
	}

	.home-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.home-hero__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		padding: 0.72rem 1.15rem;
		border-radius: 6px;
		font-weight: 500;
		text-decoration: none;
	}

	.home-hero__button--primary {
		color: var(--paper);
		background: var(--ink);
	}

	.home-hero__button--primary:hover {
		color: var(--paper);
		background: var(--flow-deep);
		transform: translateY(-1px);
	}

	.home-hero__button--secondary {
		color: var(--ink);
		border: 1px solid var(--paper-edge);
		background: transparent;
	}

	.home-hero__button--secondary:hover {
		color: var(--ink);
		background: var(--paper-2);
	}

	.home-hero__stats {
		border-left: 1px solid var(--paper-rule);
		padding-left: 1.5rem;
	}

	.home-hero__stats > .mono {
		margin-bottom: 0.7rem;
		font-size: 0.62rem;
		color: var(--ink-3);
	}

	.home-hero__stat {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.72rem 0;
		border-bottom: 1px solid var(--paper-rule);
	}

	.home-hero__stat:last-child {
		border-bottom: 0;
	}

	.home-hero__stat strong {
		font-family: var(--font-serif);
		font-size: 1.75rem;
		font-weight: 500;
		color: var(--ink);
	}

	.home-hero__stat span {
		font-size: 0.68rem;
		color: var(--ink-3);
		letter-spacing: 0.08em;
		text-align: right;
	}

	@media (max-width: 900px) {
		.home-hero {
			grid-template-columns: 1fr;
		}

		.home-hero__rail {
			display: none;
		}

		.home-hero__content {
			grid-template-columns: 1fr;
		}

		.home-hero__stats {
			border-left: 0;
			border-top: 1px solid var(--paper-rule);
			padding: 1rem 0 0;
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0 1rem;
		}

		.home-hero__stats > .mono {
			grid-column: 1 / -1;
		}
	}
</style>
