---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { filterPostsByDate } from '../lib/content';

// V3: Props 정의
interface RelatedPostItem {
  slug: string;
  score: number;
  reason: {
    ko: string;
    ja: string;
    en: string;
    zh: string;
  };
}

interface Props {
  items: RelatedPostItem[];
  language: 'ko' | 'ja' | 'en' | 'zh';
}

const { items, language } = Astro.props;

// Language-specific headings
const headings = {
  ko: '관련 글',
  ja: '関連記事',
  en: 'Related Articles',
  zh: '相关文章'
};

const heading = headings[language];

// Fetch full entries for ALL recommendations, keeping their metadata (score/reason).
// We fetch the whole list (not just the top 3) so that if a higher-ranked pick is
// unbuildable (draft/future), a lower-ranked public post can still fill the slot.
const fetched = await Promise.all(
  items.map(async (item) => {
    try {
      const post = await getEntry('blog', `${language}/${item.slug}`);
      if (!post) {
        console.warn(`[RelatedPosts] Post not found: ${language}/${item.slug}`);
        return null;
      }
      return { post, item };
    } catch (error) {
      console.error(`[RelatedPosts] Error fetching post ${item.slug}:`, error);
      return null;
    }
  })
);
const pairs = fetched.filter((entry) => entry !== null);

// Keep only recommendations whose target page is actually built. This mirrors the
// blog route's getStaticPaths (same filterPostsByDate), so a related link can never
// point at a draft/future post that 404s. Order is preserved; take the top 3.
const builtIds = new Set(filterPostsByDate(pairs.map((p) => p.post)).map((p) => p.id));

const validPosts = pairs
  .filter((p) => builtIds.has(p.post.id))
  .slice(0, 3)
  .map(({ post, item }) => ({
    slug: item.slug,
    score: item.score,
    title: post.data.title,
    description: post.data.description,
    heroImage: post.data.heroImage,
    url: `/${language}/blog/${language}/${item.slug}`,
    reason: item.reason[language]
  }));

// Don't render if no recommendations
if (validPosts.length === 0) {
  return null;
}
---

<section class="related-posts">
  <h3 class="section-title">{heading}</h3>
  <ul class="recommendations-list">
    {validPosts.map((post) => (
      <li class="recommendation-item">
        <a
          href={post.url}
          onclick={`gtag('event', 'related_post_click', {
            'target_post': '${post.slug}',
            'similarity_score': ${post.score}
          })`}
        >
          <div class="item-content">
            <h4 class="item-title">{post.title}</h4>
            {post.reason && (
              <p class="item-reason">{post.reason}</p>
            )}
          </div>
          {post.heroImage && (
            <div class="item-image">
              <Image
                src={post.heroImage}
                alt={post.title}
                width={120}
                height={80}
                loading="lazy"
              />
            </div>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .related-posts {
    margin: 3.5rem 0 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--paper-rule);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 1.5rem 0;
    color: var(--ink);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--paper-rule);
  }

  .recommendations-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recommendation-item {
    border-bottom: 1px solid var(--paper-rule);
  }

  .recommendation-item:last-child {
    border-bottom: none;
  }

  .recommendation-item a {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .recommendation-item:hover a {
    opacity: 0.8;
  }

  .item-content {
    flex: 1;
    min-width: 0;
  }

  .item-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.0625rem;
    font-family: var(--font-serif);
    font-size: 1.12rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recommendation-item:hover .item-title {
    color: var(--flow-deep);
  }

  .item-reason {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--ink-2);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .item-image {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--paper-edge);
  }

  .item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Responsive design */
  @media (max-width: 640px) {
    .related-posts {
      margin: 2.5rem 0 2rem;
      padding: 1.5rem;
    }

    .section-title {
      font-size: 1.25rem;
      margin-bottom: 1.25rem;
    }

    .recommendation-item a {
      gap: 1rem;
      padding: 1rem 0;
    }

    .item-title {
      font-size: 0.9375rem;
      margin-bottom: 0.375rem;
    }

    .item-reason {
      font-size: 0.75rem;
    }

    .item-image {
      width: 90px;
      height: 60px;
    }
  }

  /* Print styles */
  @media print {
    .related-posts {
      display: none;
    }
  }
</style>
