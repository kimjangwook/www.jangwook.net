---
interface Props {
	size?: number;
	onDark?: boolean;
	showWordmark?: boolean;
}

const { size = 40, onDark = false, showWordmark = false } = Astro.props;
const strokeColor = onDark ? 'currentColor' : 'currentColor';
---

<span class:list={['brand-lockup', { 'brand-lockup--wordmark': showWordmark }]} style={`--brand-size: ${size}px;`}>
	<svg
		class="brand-mark"
		width={size}
		height={size}
		viewBox="0 0 56 56"
		aria-hidden="true"
		focusable="false"
	>
		<path
			d="M 14 14 L 14 36 Q 14 44 8 44 Q 4 44 4 40"
			fill="none"
			stroke={strokeColor}
			stroke-width="2.5"
			stroke-linecap="round"
			stroke-linejoin="round"
		/>
		<circle cx="14" cy="8" r="2.4" fill={strokeColor} />
		<path
			d="M 22 22 L 26 40 L 32 26 L 38 40 L 42 22"
			fill="none"
			stroke={strokeColor}
			stroke-width="2.5"
			stroke-linecap="round"
			stroke-linejoin="round"
		/>
		<circle class="brand-mark__signal" cx="46" cy="22" r="2.6" />
	</svg>
	{showWordmark && (
		<span class="brand-wordmark">
			<span class="brand-wordmark__name">Jangwook <em>Kim</em></span>
			<span class="brand-wordmark__meta">jangwook.net · 김장욱</span>
		</span>
	)}
</span>

<style>
	.brand-lockup {
		display: inline-flex;
		align-items: center;
		color: var(--ink);
		line-height: 1;
	}

	:global(.dark) .brand-lockup {
		color: var(--paper);
	}

	.brand-lockup--wordmark {
		gap: 0.75rem;
	}

	.brand-mark {
		display: block;
		width: var(--brand-size);
		height: var(--brand-size);
		flex: 0 0 auto;
	}

	.brand-mark__signal {
		fill: var(--flow);
		transform-origin: 46px 22px;
		transition: transform 220ms var(--ease), opacity 220ms var(--ease);
	}

	.brand-lockup:hover .brand-mark__signal {
		opacity: 0.88;
		transform: scale(1.25);
	}

	.brand-wordmark {
		display: flex;
		flex-direction: column;
		gap: 0.28rem;
		min-width: 0;
	}

	.brand-wordmark__name {
		font-family: var(--font-serif);
		font-size: clamp(1.05rem, 1.7vw, 1.35rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		color: var(--ink);
		white-space: nowrap;
	}

	:global(.dark) .brand-wordmark__name {
		color: var(--paper);
	}

	.brand-wordmark__name em {
		font-style: italic;
	}

	.brand-wordmark__meta {
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--ink-3);
		white-space: nowrap;
	}

	:global(.dark) .brand-wordmark__meta {
		color: var(--ink-4);
	}

	@media (max-width: 520px) {
		.brand-lockup--wordmark {
			gap: 0;
		}

		.brand-wordmark__name {
			display: none;
		}

		.brand-wordmark__meta {
			display: none;
		}
	}
</style>
