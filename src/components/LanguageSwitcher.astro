---
import { languages, type Language } from '../lib/i18n/languages';
import { getRouteFromUrl } from '../lib/i18n/utils';

interface Props {
	currentLang: Language;
}

const { currentLang } = Astro.props;
const currentRoute = getRouteFromUrl(Astro.url.pathname);
const languageCodes: Record<Language, string> = {
	ko: 'KO',
	en: 'EN',
	ja: 'JA',
	zh: 'ZH',
};
---

<nav class="language-switcher" aria-label="Select language">
	{Object.entries(languages).map(([lang, label]) => {
		const language = lang as Language;
		const href = `/${language}${currentRoute.replace(/{LANG}/g, language)}`;

		return (
			<a
				href={href}
				class:list={['language-switcher__item', { 'is-active': language === currentLang }]}
				data-lang={language}
				aria-current={language === currentLang ? 'page' : undefined}
				title={label}
			>
				<span class="language-switcher__code">{languageCodes[language]}</span>
				<span class="language-switcher__label">{label}</span>
			</a>
		);
	})}
</nav>

<style>
	.language-switcher {
		display: inline-flex;
		align-items: center;
		gap: 0;
		padding: 0.2rem;
		border: 1px solid var(--paper-edge);
		border-radius: 999px;
		background: var(--paper);
	}

	.language-switcher__item {
		display: inline-flex;
		align-items: center;
		gap: 0.34rem;
		min-height: 2rem;
		padding: 0.35rem 0.72rem;
		border-radius: 999px;
		color: var(--ink-2);
		text-decoration: none;
	}

	.language-switcher__item:hover {
		color: var(--ink);
		background: var(--paper-2);
	}

	.language-switcher__item.is-active {
		color: var(--paper);
		background: var(--ink);
	}

	.language-switcher__code {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.05em;
	}

	.language-switcher__label {
		font-size: 0.78rem;
		line-height: 1;
	}

	@media (max-width: 720px) {
		.language-switcher {
			width: min(10rem, 42vw);
			min-width: 0;
			overflow-x: auto;
			scrollbar-width: none;
		}

		.language-switcher::-webkit-scrollbar {
			display: none;
		}

		.language-switcher__item {
			padding-inline: 0.56rem;
		}

		.language-switcher__label {
			display: none;
		}
	}
</style>

<script>
	import { saveLanguagePreference, type SupportedLanguage } from '../lib/language-detection';

	document.querySelectorAll<HTMLAnchorElement>('.language-switcher__item[data-lang]').forEach((link) => {
		link.addEventListener('click', () => {
			const lang = link.dataset.lang as SupportedLanguage | undefined;
			if (lang) saveLanguagePreference(lang);
		});
	});
</script>
