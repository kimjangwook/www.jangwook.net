---
import type { Language } from '../lib/i18n/languages';

interface Props {
	lang: Language;
}

const { lang } = Astro.props;

const messages = {
	ko: {
		title: '글이 도움이 되셨나요?',
		description: '더 나은 콘텐츠를 작성하는 데 힘이 됩니다. 커피 한 잔으로 응원해주세요.'
	},
	ja: {
		title: 'この記事は役に立ちましたか？',
		description: 'より良いコンテンツを作成するための力になります。コーヒー一杯で応援してください。'
	},
	en: {
		title: 'Was this helpful?',
		description: 'Your support helps me create better content. Buy me a coffee.'
	},
	zh: {
		title: '这篇文章有帮助吗？',
		description: '您的支持能帮助我创作更好的内容。请我喝杯咖啡吧。'
	}
};

const message = messages[lang];
---

<div class="support-box mt-12 pt-8">
	<div class="text-center">
		<h3>
			{message.title}
		</h3>
		<p>
			{message.description}
		</p>
		<div class="flex justify-center">
			<div id="bmc-button-container"></div>
		</div>
	</div>
</div>

<script is:inline type="text/javascript" src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js" data-name="bmc-button" data-slug="kimjangwook" data-color="#176985" data-emoji="" data-font="Geist" data-text="Buy me a coffee" data-outline-color="#1f232b" data-font-color="#ffffff" data-coffee-color="#8bd9e7"></script>

<style>
	.support-box {
		border-top: 1px solid var(--paper-rule);
	}

	.support-box h3 {
		margin: 0 0 0.7rem;
		font-family: var(--font-serif);
		font-size: 1.65rem;
		font-weight: 500;
		color: var(--ink);
	}

	.support-box p {
		max-width: 38rem;
		margin: 0 auto 1.35rem;
		color: var(--ink-2);
	}

	:global(.bmc-btn-container) {
		text-align: center;
	}
</style>
