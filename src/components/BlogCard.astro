---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
	href: string;
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: ImageMetadata;
	tags?: string[];
	readingTime: number;
	readingTimeLabel?: string;
	readMoreLabel?: string;
}

const {
	href,
	title,
	description,
	pubDate,
	heroImage,
	tags,
	readingTime,
	readingTimeLabel = 'min read',
	readMoreLabel = 'Read more',
} = Astro.props;
---

<article class="post-card">
	<a href={href} class="post-card__link">
		<div class="post-card__media" aria-hidden={!heroImage}>
			{heroImage ? (
				<Image
					src={heroImage}
					alt={title}
					width={680}
					height={430}
					class="post-card__image"
					loading="lazy"
					decoding="async"
					format="webp"
					quality={82}
				/>
			) : (
				<div class="post-card__placeholder mono uc">field<br />note</div>
			)}
			<span class="post-card__stamp mono uc">note</span>
		</div>

		<div class="post-card__body">
			<div class="post-card__meta">
				<time datetime={pubDate.toISOString()}>
					<FormattedDate date={pubDate} />
				</time>
				<span class="post-card__meta-dot"></span>
				<span>{readingTime} {readingTimeLabel}</span>
			</div>

			<h3>{title}</h3>
			<p>{description}</p>

			<div class="post-card__footer">
				<div class="post-card__tags">
					{tags?.slice(0, 3).map((tag, index) => (
						<span class:list={['post-card__tag mono', { 'is-primary': index === 0 }]}>
							<span>#</span>{tag}
						</span>
					))}
				</div>
				<span class="post-card__read mono">{readMoreLabel}</span>
			</div>
		</div>
	</a>
</article>

<style>
	.post-card {
		position: relative;
		border-bottom: 1px solid var(--paper-rule);
	}

	.post-card__link {
		display: grid;
		grid-template-columns: minmax(11rem, 0.9fr) minmax(0, 1.1fr);
		gap: 1.35rem;
		padding: 1.35rem 0;
		color: inherit;
		text-decoration: none;
	}

	.post-card__media {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border: 1px solid var(--paper-edge);
		border-radius: 6px;
		background: repeating-linear-gradient(
			135deg,
			var(--paper-2) 0,
			var(--paper-2) 8px,
			var(--paper) 8px,
			var(--paper) 16px
		);
	}

	.post-card__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		filter: saturate(0.92);
		transform: scale(1.001);
		transition: transform 520ms var(--ease-out), filter 220ms var(--ease);
	}

	.post-card__placeholder {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		text-align: center;
		font-size: 0.68rem;
		line-height: 1.8;
		color: var(--ink-3);
	}

	.post-card__stamp {
		position: absolute;
		left: 0.65rem;
		top: 0.65rem;
		padding: 0.22rem 0.42rem;
		border: 1px solid var(--paper-edge);
		border-radius: 3px;
		background: color-mix(in oklch, var(--paper) 88%, transparent);
		color: var(--ink-2);
		font-size: 0.58rem;
	}

	.post-card__body {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		min-width: 0;
		padding-top: 0.18rem;
	}

	.post-card__meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.68rem;
		color: var(--ink-3);
	}

	.post-card__meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 999px;
		background: var(--ink-4);
	}

	.post-card h3 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: clamp(1.45rem, 2.4vw, 1.95rem);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: -0.015em;
		color: var(--ink);
		text-wrap: balance;
	}

	.post-card p {
		margin: 0;
		font-family: var(--font-serif);
		font-size: 0.96rem;
		line-height: 1.58;
		color: var(--ink-2);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card__footer {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: auto;
	}

	.post-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.38rem;
		min-width: 0;
	}

	.post-card__tag {
		display: inline-flex;
		align-items: center;
		gap: 0.12rem;
		padding: 0.22rem 0.45rem;
		border: 1px solid var(--paper-edge);
		border-radius: 4px;
		color: var(--ink-3);
		font-size: 0.66rem;
		line-height: 1;
	}

	.post-card__tag.is-primary {
		color: var(--flow-deep);
		background: var(--flow-soft);
		border-color: transparent;
	}

	.post-card__tag span {
		color: var(--ink-4);
	}

	.post-card__read {
		margin-left: auto;
		color: var(--flow-deep);
		font-size: 0.68rem;
		white-space: nowrap;
	}

	.post-card__read::after {
		content: ' ->';
	}

	.post-card__link:hover .post-card__image {
		filter: saturate(1.02);
		transform: scale(1.035);
	}

	.post-card__link:hover h3 {
		color: var(--flow-deep);
	}

	@media (max-width: 720px) {
		.post-card__link {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
	}
</style>
