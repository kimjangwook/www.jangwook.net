---
/**
 * FAQ Component for AEO (Answer Engine Optimization)
 *
 * This component renders FAQ sections optimized for:
 * - Google AI Overview
 * - ChatGPT / Perplexity / Claude
 * - Voice Search (Google Assistant, Alexa)
 * - Featured Snippets
 *
 * Usage:
 * <FAQ items={[{ question: "...", answer: "..." }]} lang="ko" />
 */

export interface FAQItem {
	question: string;
	answer: string;
}

interface Props {
	items: FAQItem[];
	title?: string;
	lang?: 'ko' | 'en' | 'ja' | 'zh';
}

const { items, title, lang = 'en' } = Astro.props;

// Default titles by language
const defaultTitles = {
	ko: '자주 묻는 질문',
	en: 'Frequently Asked Questions',
	ja: 'よくある質問',
	zh: '常见问题'
};

const sectionTitle = title || defaultTitles[lang];
---

<section class="faq-section py-14" aria-labelledby="faq-title">
	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
		<h2 id="faq-title">
			{sectionTitle}
		</h2>

		<div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
			{items.map((item, index) => (
				<details
					class="faq-item group overflow-hidden"
					itemscope
					itemprop="mainEntity"
					itemtype="https://schema.org/Question"
					open={index === 0}
				>
					<summary
						class="faq-question flex items-center justify-between p-5 cursor-pointer transition-colors"
						itemprop="name"
					>
						<span>
							{item.question}
						</span>
						<svg
							class="w-5 h-5 flex-shrink-0 transform group-open:rotate-180 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
						</svg>
					</summary>
					<div
						class="faq-answer px-5 pb-5 leading-relaxed"
						itemscope
						itemprop="acceptedAnswer"
						itemtype="https://schema.org/Answer"
					>
						<div itemprop="text" set:html={item.answer} />
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.faq-section {
		background: var(--paper);
		border-top: 1px solid var(--paper-rule);
		border-bottom: 1px solid var(--paper-rule);
	}

	.faq-section h2 {
		margin: 0 0 2rem;
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		font-weight: 500;
		color: var(--ink);
	}

	.faq-item {
		border: 1px solid var(--paper-rule);
		border-radius: 8px;
		background: var(--paper-2);
	}

	.faq-question:hover {
		background: var(--paper);
	}

	.faq-question span {
		padding-right: 1rem;
		font-family: var(--font-serif);
		font-size: clamp(1rem, 2vw, 1.15rem);
		font-weight: 500;
		color: var(--ink);
	}

	.faq-question svg {
		color: var(--flow-deep);
	}

	.faq-answer {
		color: var(--ink-2);
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary {
		list-style: none;
	}

	.faq-answer {
		animation: fadeIn 0.3s ease-out;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
