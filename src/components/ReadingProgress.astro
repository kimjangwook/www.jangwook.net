<div id="reading-progress-container">
  <div id="reading-progress" class="reading-progress"></div>
</div>

<script>
  const progressBar = document.getElementById('reading-progress');

  if (progressBar) {
    const updateProgress = () => {
      const windowHeight = window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight - windowHeight;
      const scrollTop = window.scrollY;
      const progress = documentHeight > 0 ? Math.min((scrollTop / documentHeight) * 100, 100) : 100;

      progressBar.style.setProperty('--reading-progress', `${progress}%`);
      progressBar.style.width = `${progress}%`;

      if (progress >= 80) {
        progressBar.classList.add('near-complete');
      } else {
        progressBar.classList.remove('near-complete');
      }
    };

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateProgress();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateProgress();
  }
</script>

<style>
  #reading-progress {
    width: var(--reading-progress, 0%);
  }
</style>
