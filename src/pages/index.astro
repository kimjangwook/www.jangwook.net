---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { filterPostsByDate } from '../lib/content';

const allPosts = await getCollection('blog');
const publishedPosts = filterPostsByDate(allPosts);

const languageMeta = [
	{
		code: 'ko',
		name: '한국어',
		label: '김장욱의 기술 블로그',
		description: 'AI 에이전트, 자동화, 개발 도구, 소프트웨어 제작 과정을 한국어로 기록합니다.',
	},
	{
		code: 'en',
		name: 'English',
		label: "Kim Jangwook's Tech Blog",
		description: 'Personal notes on AI agents, automation, developer tools, and building software.',
	},
	{
		code: 'ja',
		name: '日本語',
		label: 'Kim Jangwookの個人技術ブログ',
		description: 'AIエージェント、自動化、開発ツール、ソフトウェア開発の記録です。',
	},
	{
		code: 'zh',
		name: '简体中文',
		label: 'Kim Jangwook 的个人技术博客',
		description: '记录 AI 代理、自动化、开发工具和软件构建过程。',
	},
] as const;

type LanguageCode = typeof languageMeta[number]['code'];

const latestPostsByLanguage = {
	ko: publishedPosts
		.filter((post) => post.id.startsWith('ko/'))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		.slice(0, 3),
	en: publishedPosts
		.filter((post) => post.id.startsWith('en/'))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		.slice(0, 3),
	ja: publishedPosts
		.filter((post) => post.id.startsWith('ja/'))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		.slice(0, 3),
	zh: publishedPosts
		.filter((post) => post.id.startsWith('zh/'))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		.slice(0, 3),
} satisfies Record<LanguageCode, typeof publishedPosts>;

const focusItems = [
	'AI agent systems',
	'Automation workflows',
	'Developer tools',
	'Product build logs',
];

const formatDate = (date: Date, lang: LanguageCode) => {
	const locale = lang === 'zh' ? 'zh-CN' : lang;
	return new Intl.DateTimeFormat(locale, {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	}).format(date);
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} enableAds={true} />
	</head>
	<body>
		<Header lang="en" />

		<main>
			<section class="root-hero bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
					<div class="grid lg:grid-cols-[1fr_320px] gap-12 items-end">
						<div>
							<p class="text-sm font-semibold uppercase tracking-[0.18em] text-teal-700 dark:text-teal-300 mb-4">
								jangwook.net
							</p>
							<h1 class="text-4xl md:text-6xl font-bold tracking-tight text-gray-950 dark:text-gray-50 mb-6">
								Kim Jangwook
							</h1>
							<p class="max-w-2xl text-lg md:text-xl leading-relaxed text-gray-600 dark:text-gray-300">
								Personal technical notes on AI agents, automation, developer tools, and the process of building software.
							</p>
							<div class="mt-8 grid sm:grid-cols-2 gap-3 max-w-3xl">
								{languageMeta.map((lang) => (
									<a
										href={`/${lang.code}/`}
										class="group border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 hover:bg-white dark:hover:bg-gray-800 rounded-lg px-4 py-4 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-500"
									>
										<span class="flex items-center justify-between gap-4">
											<span>
												<span class="block text-sm font-semibold text-gray-950 dark:text-gray-50">{lang.name}</span>
												<span class="block mt-1 text-sm text-gray-600 dark:text-gray-400">{lang.label}</span>
											</span>
											<svg class="w-4 h-4 text-teal-700 dark:text-teal-300 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
											</svg>
										</span>
									</a>
								))}
							</div>
						</div>

						<aside class="border-l-2 border-teal-600 dark:border-teal-400 pl-6">
							<h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500 dark:text-gray-400 mb-4">
								Current Focus
							</h2>
							<ul class="space-y-3 text-gray-800 dark:text-gray-200">
								{focusItems.map((item) => (
									<li class="flex items-start gap-3">
										<span class="mt-2 h-1.5 w-1.5 rounded-full bg-teal-600 dark:bg-teal-300"></span>
										<span>{item}</span>
									</li>
								))}
							</ul>
						</aside>
					</div>
				</div>
			</section>

			<section class="root-latest max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-16">
				<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.16em] text-teal-700 dark:text-teal-300 mb-3">
							Latest Notes
						</p>
						<h2 class="text-3xl font-bold text-gray-950 dark:text-gray-50">Recent writing by language</h2>
					</div>
					<p class="max-w-xl text-sm leading-6 text-gray-600 dark:text-gray-400">
						The root page stays intentionally small. Choose a language, then read the full archive and related posts there.
					</p>
				</div>

				<div class="grid lg:grid-cols-2 gap-x-10 gap-y-12">
					{languageMeta.map((lang) => (
						<section aria-labelledby={`${lang.code}-latest-title`}>
							<div class="flex items-center justify-between gap-4 border-b border-gray-200 dark:border-gray-800 pb-3 mb-4">
								<div>
									<h3 id={`${lang.code}-latest-title`} class="text-xl font-bold text-gray-950 dark:text-gray-50">
										{lang.name}
									</h3>
									<p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{lang.description}</p>
								</div>
								<a href={`/${lang.code}/blog/`} class="text-sm font-semibold text-teal-700 dark:text-teal-300 hover:underline">
									Archive
								</a>
							</div>

							<div class="space-y-5">
								{latestPostsByLanguage[lang.code].map((post) => {
									const slug = post.id.replace(`${lang.code}/`, '');
									return (
										<article>
											<a
												href={`/${lang.code}/blog/${lang.code}/${slug}/`}
												class="group block rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-500"
											>
												<time datetime={post.data.pubDate.toISOString()} class="text-xs text-gray-500 dark:text-gray-500">
													{formatDate(post.data.pubDate, lang.code)}
												</time>
												<h4 class="mt-1 text-base font-semibold leading-6 text-gray-950 dark:text-gray-50 group-hover:text-teal-700 dark:group-hover:text-teal-300">
													{post.data.title}
												</h4>
												<p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-400 line-clamp-2">
													{post.data.description}
												</p>
											</a>
										</article>
									);
								})}
							</div>
						</section>
					))}
				</div>
			</section>
		</main>

		<Footer lang="en" />

		<style>
			.root-hero {
				background: var(--paper);
				border-color: var(--paper-rule);
			}

			.root-hero h1 {
				font-family: var(--font-serif);
				font-size: clamp(3.6rem, 8vw, 6.5rem);
				font-weight: 500;
				line-height: 0.98;
				letter-spacing: -0.035em;
				color: var(--ink);
			}

			.root-hero p,
			.root-latest p {
				color: var(--ink-2);
			}

			.root-hero .text-teal-700,
			.root-latest .text-teal-700 {
				color: var(--flow-deep);
			}

			.root-hero .border-teal-600 {
				border-color: var(--flow);
			}

			.root-hero .bg-teal-600 {
				background: var(--flow);
			}

			.root-hero a,
			.root-latest a {
				border-color: var(--paper-rule);
				background: var(--paper-2);
			}

			.root-hero a:hover,
			.root-latest a:hover {
				background: var(--paper);
			}

			.root-latest h2,
			.root-latest h3,
			.root-latest h4 {
				color: var(--ink);
			}

			.root-latest h2 {
				font-family: var(--font-serif);
				font-weight: 500;
				letter-spacing: -0.02em;
			}
		</style>
	</body>
</html>
