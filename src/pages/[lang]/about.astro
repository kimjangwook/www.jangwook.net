---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { Image } from 'astro:assets';
import { getStaticPaths as getI18nStaticPaths } from '../../lib/i18n/utils';
import { useTranslations, type Language } from '../../lib/i18n/languages';
import shadowDashIcon from '../../assets/portfolio/shadow-dash/app_icon.jpg';

export function getStaticPaths() {
	return getI18nStaticPaths();
}

const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={t('nav.about')} description={t('site.description')} />
	</head>
	<body>
		<Header lang={lang} />
		<main class="about-page max-w-5xl mx-auto px-4 py-12">
			<!-- Profile Section -->
			<section class="about-profile mb-16">
				<div>
					<p class="mono uc about-profile__kicker"><span class="flow-dot"></span> the writer</p>
					<h1>Kim<br /><em>Jangwook.</em></h1>
					<p class="mono about-profile__names">김장욱 · キム・ジャンウク · 金张旭</p>
				</div>
				<div class="about-profile__body">
					<p class="about-profile__tagline">Renew day by day.</p>
					{lang === 'ko' ? (
						<div>
							<p>
								안녕하세요. 저는 김장욱(Kim Jangwook)입니다. jangwook.net은 제가 AI 에이전트, 자동화, 개발 도구, 제품 제작 과정에서 배운 것을 기록하는 개인 기술 블로그입니다.
							</p>
								<p>
									Effloow 같은 콘텐츠 서비스와 Agent Effi Flow 같은 자동화 시스템은 각각 별도 도메인에서 운영하고, 이곳은 실험 과정과 구현 로그, 판단 근거를 남기는 개인 공간으로 정리하고 있습니다.
								</p>
							<p>
								글은 완성된 홍보 문구보다 실제로 해본 것, 실패한 것, 다시 정리한 것을 중심으로 씁니다.
							</p>
						</div>
					) : lang === 'ja' ? (
						<div>
							<p>
								こんにちは。Kim Jangwookです。jangwook.netは、AIエージェント、自動化、開発ツール、プロダクト制作の過程で学んだことを記録する個人技術ブログです。
							</p>
								<p>
									EffloowのようなコンテンツサービスやAgent Effi Flowのような自動化システムは、それぞれ別ドメインで運営し、ここでは実験の過程、実装ログ、判断の理由を個人の記録として整理しています。
								</p>
							<p>
								完成した宣伝文句よりも、実際に試したこと、失敗したこと、考え直したことを中心に書いています。
							</p>
						</div>
					) : lang === 'zh' ? (
						<div>
							<p>
								您好，我是 Kim Jangwook。jangwook.net 是我的个人技术博客，用来记录 AI 代理、自动化、开发工具和产品构建过程中学到的内容。
							</p>
								<p>
									Effloow 这样的内容服务和 Agent Effi Flow 这样的自动化系统会分别在独立域名运营，而这里更像是个人记录，用来整理实验过程、实现日志和决策依据。
								</p>
							<p>
								这里的文章更关注真实尝试、失败经验和重新整理后的思考，而不是完成后的宣传文案。
							</p>
						</div>
					) : (
						<div>
							<p>
								Hello, I am Kim Jangwook. jangwook.net is my personal technology blog for recording what I learn while building AI agents, automation, developer tools, and software products.
							</p>
								<p>
									Content services such as Effloow and automation systems such as Agent Effi Flow live on separate domains. This site is the personal space where I keep experiments, implementation logs, and the reasoning behind technical decisions.
								</p>
							<p>
								I write less like finished marketing copy and more like a working notebook: what I tried, what broke, and what I would do differently next time.
							</p>
						</div>
					)}
				</div>
			</section>

			<!-- Careers Section -->
			<section class="mb-16">
				<h2 class="text-3xl font-bold mb-6 border-b border-gray-200 dark:border-gray-700 pb-2 text-gray-900 dark:text-gray-100">Careers</h2>
				<div class="space-y-6">
					<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">SPIKA Inc.</h3>
					</div>
					<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">Bravance Technologies Inc.</h3>
					</div>
					<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">Connecty Inc.</h3>
					</div>
				</div>
			</section>

			<!-- Portfolio Section -->
			<section class="mb-16">
				<h2 class="text-3xl font-bold mb-6 border-b border-gray-200 dark:border-gray-700 pb-2 text-gray-900 dark:text-gray-100">Portfolio</h2>

				<h3 class="text-2xl font-semibold mb-4 text-gray-900 dark:text-gray-100">{lang === 'ko' ? '개인 프로젝트' : lang === 'ja' ? '個人プロジェクト' : lang === 'zh' ? '个人项目' : 'My Projects'}</h3>
				<div class="space-y-6 mb-8">
			<!-- Shadow Dash -->
			<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
				<div class="flex items-start gap-4">
					<a href={`/${lang}/portfolio/shadow-dash`} class="flex-shrink-0">
						<Image
							src={shadowDashIcon}
							alt="Shadow Dash"
							width={64}
							height={64}
							class="rounded-xl shadow-md"
						/>
					</a>
					<div class="flex-1">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							<a href={`/${lang}/portfolio/shadow-dash`} class="text-accent hover:underline dark:text-accent">
								Shadow Dash
							</a>
						</h4>
						<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Tech: Tauri v2, SvelteKit, PixiJS v8, Rust, TypeScript</p>
						<p class="text-gray-700 dark:text-gray-300">
							{lang === 'ko' ? (
								'빛과 그림자를 넘나드는 원터치 플랫포머 게임. 4초마다 낮과 밤이 전환되며, 낮에는 그림자 위로, 밤에는 빛 위로 점프해야 합니다. iOS 앱으로 출시 예정.'
							) : lang === 'ja' ? (
								'光と影を駆け抜けるワンタッチプラットフォーマー。4秒ごとに昼夜が切り替わり、昼は影の上、夜は光の上をジャンプします。iOS向けリリース予定。'
							) : lang === 'zh' ? (
								'穿越光与影的一触式平台游戏。每4秒昼夜切换，白天在阴影上跳跃，夜晚在光芒上跳跃。即将在iOS发布。'
							) : (
								'One-touch platformer game traversing light and shadow. Day and night switch every 4 seconds - jump on shadows during day, on light during night. Coming to iOS.'
							)}
						</p>
						<div class="mt-3 flex gap-2">
							<span class="px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded text-xs font-medium">
								{lang === 'ko' ? '개발 완료' : lang === 'ja' ? '開発完了' : lang === 'zh' ? '开发完成' : 'Development Complete'}
							</span>
							<span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 rounded text-xs font-medium">iOS</span>
						</div>
					</div>
				</div>
			</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
					<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
						<a href="https://agent-effi-flow.jangwook.net/" target="_blank" class="text-accent hover:underline dark:text-accent">
							Agent Effi Flow
						</a>
					</h4>
					<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Tech: SvelteKit, Supabase, Google Gemini API, Stripe</p>
					<p class="text-gray-700 dark:text-gray-300">
						{lang === 'ko' ? (
							'AI 기반 B2B SaaS OCR 자동화 시스템. 면세처리 OCR과 경리 OCR을 제공하며, 일본 인바운드 관광 비즈니스와 중소기업 경리 팀을 타겟으로 합니다.'
						) : lang === 'ja' ? (
							'AIベースのB2B SaaS OCR自動化システム。免税処理OCRと経理OCRを提供し、日本のインバウンド観光ビジネスと中小企業の経理チームをターゲットにしています。'
						) : lang === 'zh' ? (
							'基于AI的B2B SaaS OCR自动化系统。提供免税处理OCR和会计OCR，面向日本入境旅游企业和中小企业会计团队。'
						) : (
							'AI-powered B2B SaaS OCR automation system. Provides Receipt OCR for Tax Refund and Accounting OCR services targeting Japanese inbound tourism businesses and SME accounting teams.'
						)}
					</p>
				</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
					<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
						<a href="https://www.effloow.com" target="_blank" class="text-accent hover:underline dark:text-accent">
							Effloow
						</a>
					</h4>
					<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Tech: Paperclip, Codex, Markdown, GA4</p>
					<p class="text-gray-700 dark:text-gray-300">
						{lang === 'ko' ? (
							'AI 에이전트가 콘텐츠 기획, 작성, 운영 이슈를 처리하는 콘텐츠 비즈니스 실험. www.effloow.com에서 별도 서비스로 운영하며, 이 블로그와는 분리된 프로젝트입니다.'
						) : lang === 'ja' ? (
							'AIエージェントがコンテンツ企画、執筆、運用課題を処理するコンテンツビジネス実験。www.effloow.comで別サービスとして運営し、このブログとは分離したプロジェクトです。'
						) : lang === 'zh' ? (
							'由 AI 代理处理内容策划、写作和运营事项的内容业务实验。在 www.effloow.com 作为独立服务运营，并与此博客分离。'
						) : (
							'A content-business experiment where AI agents handle planning, writing, and operational issues. It runs as a separate service at www.effloow.com, apart from this blog.'
						)}
					</p>
				</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							<a href="https://github.com/kimjangwook/ssr-repeater" target="_blank" class="text-accent hover:underline dark:text-accent">
								{lang === 'ko' ? 'SSR 설문 분석' : lang === 'ja' ? 'SSRアンケート分析' : lang === 'zh' ? 'SSR 问卷分析' : 'SSR Survey Analysis'}
							</a>
						</h4>
						<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Tech: Python, OpenAI API, LLM, Data Science</p>
						<p class="text-gray-700 dark:text-gray-300">
							{lang === 'ko' ? (
								'LLM 기반 의미론적 유사도 평가 방법론을 활용한 블로그 재방문 의향 분석. 15개 페르소나와 5개 콘텐츠 카테고리에 대해 225개 평가를 수행하여 ICC 신뢰도 0.833을 달성. 전통적 설문조사 대비 비용 효율적 대안(평가당 $0.016 vs $1-5).'
							) : lang === 'ja' ? (
								'LLMベースの意味的類似性評価手法を用いたブログ再訪問意図分析。15のペルソナと5つのコンテンツカテゴリに対して225件の評価を実施し、ICC信頼性0.833を達成。従来の調査と比較して費用対効果の高い代替手段（評価あたり$0.016 vs $1-5）。'
							) : lang === 'zh' ? (
								'基于LLM的语义相似度评估方法论，用于分析博客重访意向。针对15个人物角色和5个内容类别进行了225次评估，实现了ICC信度0.833。相比传统问卷调查更具成本效益（每次评估$0.016 vs $1-5）。'
							) : (
								'LLM-based Semantic Similarity Rating methodology for analyzing blog revisit intent. Conducted 225 evaluations with 15 diverse personas across 5 content categories, achieving ICC reliability of 0.833. Cost-efficient alternative to traditional surveys ($0.016 per evaluation vs $1-5).'
							)}
						</p>
					</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							<a href="https://kimjangwook.github.io/svelte-weather/public/" target="_blank" class="text-accent hover:underline dark:text-accent">
								{lang === 'ko' ? '날씨 정보 시스템' : lang === 'ja' ? '気象情報取得システム' : lang === 'zh' ? '天气信息系统' : 'Weather Information System'}
							</a>
						</h4>
						<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Tech: Svelte</p>
						<p class="text-gray-700 dark:text-gray-300">
							{lang === 'ko' ? (
								'Svelte 프레임워크로 구축된 현대적인 날씨 애플리케이션. 반응형 사용자 인터페이스로 실시간 기상 데이터를 제공합니다.'
							) : lang === 'ja' ? (
								'Svelteフレームワークで構築された最新の天気アプリケーション。レスポンシブなユーザーインターフェースでリアルタイムの気象データを提供します。'
							) : lang === 'zh' ? (
								'基于Svelte框架构建的现代化天气应用程序。通过响应式用户界面提供实时气象数据。'
							) : (
								'A modern weather application built with Svelte framework, providing real-time meteorological data with a responsive user interface.'
							)}
						</p>
					</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							<a href="https://kimjangwook.github.io/letsencrypt-domain-checker/public/" target="_blank" class="text-accent hover:underline dark:text-accent">
								{lang === 'ko' ? "Let's Encrypt 도메인 체커" : lang === 'ja' ? "Let's Encrypt ドメインチェッカー" : lang === 'zh' ? "Let's Encrypt 域名检查器" : "Let's Encrypt Domain Checker"}
							</a>
						</h4>
						<p class="text-gray-700 dark:text-gray-300">
							{lang === 'ko' ? (
								"도메인의 Let's Encrypt SSL 인증서를 확인하고 관리하는 도구입니다."
							) : lang === 'ja' ? (
								"ドメインのLet's Encrypt SSL証明書を確認および管理するツールです。"
							) : lang === 'zh' ? (
								"用于检查和管理域名Let's Encrypt SSL证书的工具。"
							) : (
								"A tool for checking and managing Let's Encrypt SSL certificates for domains."
							)}
						</p>
					</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							<a href="https://drone-info.jangwook.net/" target="_blank" class="text-accent hover:underline dark:text-accent">
								{lang === 'ko' ? '드론 정보 모음' : lang === 'ja' ? 'ドローン情報まとめ' : lang === 'zh' ? '无人机信息汇总' : 'Drone Information Hub'}
							</a>
						</h4>
						<p class="text-gray-700 dark:text-gray-300">
							{lang === 'ko' ? (
								'드론, 규정, 모범 사례에 대한 종합 정보 리소스입니다.'
							) : lang === 'ja' ? (
								'ドローン、規制、ベストプラクティスに関する包括的な情報リソースです。'
							) : lang === 'zh' ? (
								'关于无人机、法规和最佳实践的综合信息资源。'
							) : (
								'Comprehensive information resource about drones, regulations, and best practices.'
							)}
						</p>
					</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							<a href="https://libraries.jangwook.net/" target="_blank" class="text-accent hover:underline dark:text-accent">
								{lang === 'ko' ? '실무에 유용한 라이브러리' : lang === 'ja' ? '仕事に使えるライブラリー' : lang === 'zh' ? '实用开发库集合' : 'Practical Libraries Collection'}
							</a>
						</h4>
						<p class="text-gray-700 dark:text-gray-300">
							{lang === 'ko' ? (
								'전문 개발 작업을 위한 실용적인 라이브러리 및 도구 모음입니다.'
							) : lang === 'ja' ? (
								'プロフェッショナル開発作業のための実用的なライブラリとツールの厳選コレクションです。'
							) : lang === 'zh' ? (
								'为专业开发工作精选的实用库和工具集合。'
							) : (
								'A curated collection of practical libraries and tools for professional development work.'
							)}
						</p>
					</div>
				</div>

				<h3 class="text-2xl font-semibold mb-4 text-gray-900 dark:text-gray-100">{lang === 'ko' ? '프로젝트 경력' : lang === 'ja' ? '業務経験' : lang === 'zh' ? '项目经验' : 'Works'}</h3>
				<div class="space-y-6">
				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							{lang === 'ko' ? '청구서 관리 시스템' : lang === 'ja' ? '請求書管理システム' : lang === 'zh' ? '发票管理系统' : 'Invoice Management System'}
						</h4>
						<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Tech: Laravel, Vue.js, AWS</p>
						<p class="text-gray-700 mb-3">
							{lang === 'ko' ? (
								'프리랜서의 청구서 관리를 지원하기 위해 만들어진 애플리케이션입니다.'
							) : lang === 'ja' ? (
								'フリーランサーの請求書管理を支援するために作成されたアプリケーションです。'
							) : lang === 'zh' ? (
								'为协助自由职业者进行发票管理而创建的应用程序。'
							) : (
								'An application created to assist freelancers with invoice management.'
							)}
						</p>
						<ul class="list-disc list-inside space-y-1 text-gray-700 dark:text-gray-300">
							<li>{lang === 'ko' ? '프로필 관리' : lang === 'ja' ? 'プロフィール管理' : lang === 'zh' ? '个人资料管理' : 'Profile management'}</li>
							<li>{lang === 'ko' ? '거래처 관리' : lang === 'ja' ? '請求先パートナー管理' : lang === 'zh' ? '客户管理' : 'Billing partner management'}</li>
							<li>{lang === 'ko' ? '청구서 관리' : lang === 'ja' ? '請求書管理' : lang === 'zh' ? '发票管理' : 'Invoice management'}</li>
						</ul>
					</div>

				<div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700">
						<h4 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100">
							{lang === 'ko' ? '대시보드 시스템' : lang === 'ja' ? 'ダッシュボード' : lang === 'zh' ? '仪表盘系统' : 'Dashboard'}
