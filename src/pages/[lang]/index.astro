---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import HeroSection from '../../components/HeroSection.astro';
import FAQ from '../../components/FAQ.astro';
import { getStaticPaths as getI18nStaticPaths } from '../../lib/i18n/utils';
import { useTranslations, type Language } from '../../lib/i18n/languages';
import { filterPostsByDate, calculateReadingTime } from '../../lib/content';
import { getFAQItems } from '../../data/faq';

export function getStaticPaths() {
	return getI18nStaticPaths();
}

const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);
const faqItems = getFAQItems(lang as 'ko' | 'en' | 'ja' | 'zh');

// Get latest 6 blog posts filtered by language
// - ko/filename.md -> ko
// - en/filename.md -> en
// - ja/filename.md -> ja
const allPosts = await getCollection('blog');
const posts = filterPostsByDate(allPosts)
	.filter((post) => post.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={t('site.title')}
			description={t('site.description')}
			faqData={faqItems}
			isHomePage={true}
			enableAds={true}
		/>
	</head>
	<body>
		<Header lang={lang} />
		<HeroSection lang={lang} />

		<!-- Latest Posts Section -->
		<main class="latest-notes max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
			<div class="latest-notes__header">
				<div>
					<p class="mono uc"><span class="flow-dot"></span> latest</p>
					<h2>{t('blog.latestPosts')}</h2>
				</div>
				<a
					href={`/${lang}/blog`}
					class="latest-notes__archive mono"
				>
					{t('blog.viewAll')}
				</a>
			</div>

			<div class="latest-notes__list">
				{posts.map((post) => (
					<BlogCard
						href={`/${lang}/blog/${post.id}/`}
						title={post.data.title}
						description={post.data.description}
						pubDate={post.data.pubDate}
						heroImage={post.data.heroImage}
						tags={post.data.tags}
						readingTime={calculateReadingTime(post.body || '')}
						readingTimeLabel={t('blog.readTime')}
						readMoreLabel={t('blog.readMore')}
					/>
				))}
			</div>
		</main>

		<!-- FAQ Section for AEO (Answer Engine Optimization) -->
		<FAQ items={faqItems} lang={lang as 'ko' | 'en' | 'ja' | 'zh'} />

		<Footer lang={lang} />
	</body>
</html>

<style>
	.latest-notes__header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 1.2rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--paper-rule);
	}

	.latest-notes__header p {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		margin: 0 0 0.5rem;
		font-size: 0.68rem;
		color: var(--flow-deep);
	}

	.latest-notes__header h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.05;
		letter-spacing: -0.02em;
	}

	.latest-notes__archive {
		color: var(--flow-deep);
		font-size: 0.72rem;
		text-decoration: none;
		white-space: nowrap;
	}

	.latest-notes__archive::after {
		content: ' ->';
	}

	.latest-notes__list {
		display: grid;
		gap: 0;
	}

	@media (max-width: 640px) {
		.latest-notes__header {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
