---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { getStaticPaths as getI18nStaticPaths } from '../../../lib/i18n/utils';
import { useTranslations, type Language } from '../../../lib/i18n/languages';
import { filterPostsByDate, calculateReadingTime } from '../../../lib/content';

export async function getStaticPaths() {
	return getI18nStaticPaths();
}

const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);

// Filter posts by language based on folder structure:
// - ko/filename.md -> ko
// - en/filename.md -> en
// - ja/filename.md -> ja
const allPosts = await getCollection('blog');
const posts = filterPostsByDate(allPosts)
	.filter((post) => post.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={t('nav.blog')} description={t('site.description')} enableAds={true} />
	</head>
	<body>
		<Header lang={lang} />
		<main class="blog-archive max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
			<section>
				<header class="blog-archive__header">
					<p class="mono uc"><span class="flow-dot"></span> archive</p>
					<h1>{t('nav.blog')}</h1>
				</header>
				<div class="blog-archive__list">
					{
						posts.map((post) => (
							<BlogCard
								href={`/${lang}/blog/${post.id}/`}
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								heroImage={post.data.heroImage}
								tags={post.data.tags}
								readingTime={calculateReadingTime(post.body || '')}
								readingTimeLabel={t('blog.readTime')}
								readMoreLabel={t('blog.readMore')}
							/>
						))
					}
				</div>
			</section>
		</main>
		<Footer lang={lang} />
	</body>
</html>

<style>
	.blog-archive__header {
		margin-bottom: 1.25rem;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid var(--paper-rule);
	}

	.blog-archive__header p {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		margin: 0 0 0.65rem;
		font-size: 0.68rem;
		color: var(--flow-deep);
	}

	.blog-archive__header h1 {
		margin: 0;
		font-size: clamp(2.6rem, 6vw, 5rem);
		line-height: 0.98;
		letter-spacing: -0.03em;
	}

	.blog-archive__list {
		display: grid;
		gap: 0;
	}
</style>
