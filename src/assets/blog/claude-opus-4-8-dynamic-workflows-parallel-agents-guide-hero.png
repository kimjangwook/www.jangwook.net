<svg xmlns="http://www.w3.org/2000/svg" width="1020" height="510" viewBox="0 0 1020 510">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#1a2035"/>
      <stop offset="100%" style="stop-color:#0d1117"/>
    </radialGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#58a6ff;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#58a6ff;stop-opacity:0"/>
    </radialGradient>
    <filter id="blur">
      <feGaussianBlur stdDeviation="3"/>
    </filter>
    <filter id="glow-filter">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <!-- Background -->
  <rect width="1020" height="510" fill="url(#bg)"/>
  <!-- Grid lines subtle -->
  <g opacity="0.06" stroke="#58a6ff" stroke-width="0.5">
    <line x1="0" y1="51" x2="1020" y2="51"/>
    <line x1="0" y1="102" x2="1020" y2="102"/>
    <line x1="0" y1="153" x2="1020" y2="153"/>
    <line x1="0" y1="204" x2="1020" y2="204"/>
    <line x1="0" y1="255" x2="1020" y2="255"/>
    <line x1="0" y1="306" x2="1020" y2="306"/>
    <line x1="0" y1="357" x2="1020" y2="357"/>
    <line x1="0" y1="408" x2="1020" y2="408"/>
    <line x1="0" y1="459" x2="1020" y2="459"/>
    <line x1="102" y1="0" x2="102" y2="510"/>
    <line x1="204" y1="0" x2="204" y2="510"/>
    <line x1="306" y1="0" x2="306" y2="510"/>
    <line x1="408" y1="0" x2="408" y2="510"/>
    <line x1="510" y1="0" x2="510" y2="510"/>
    <line x1="612" y1="0" x2="612" y2="510"/>
    <line x1="714" y1="0" x2="714" y2="510"/>
    <line x1="816" y1="0" x2="816" y2="510"/>
    <line x1="918" y1="0" x2="918" y2="510"/>
  </g>
  <!-- Connection lines from center to ring 1 -->
  <g stroke="#58a6ff" stroke-width="1" opacity="0.5">
    <line x1="510" y1="210" x2="510" y2="140"/>
    <line x1="510" y1="210" x2="580" y2="155"/>
    <line x1="510" y1="210" x2="620" y2="210"/>
    <line x1="510" y1="210" x2="580" y2="265"/>
    <line x1="510" y1="210" x2="510" y2="280"/>
    <line x1="510" y1="210" x2="440" y2="265"/>
    <line x1="510" y1="210" x2="400" y2="210"/>
    <line x1="510" y1="210" x2="440" y2="155"/>
  </g>
  <!-- Connection lines from ring 1 to ring 2 -->
  <g stroke="#8b5cf6" stroke-width="0.8" opacity="0.4">
    <line x1="510" y1="140" x2="480" y2="75"/>
    <line x1="510" y1="140" x2="555" y2="78"/>
    <line x1="580" y1="155" x2="645" y2="115"/>
    <line x1="620" y1="210" x2="695" y2="185"/>
    <line x1="620" y1="210" x2="700" y2="240"/>
    <line x1="580" y1="265" x2="640" y2="320"/>
    <line x1="510" y1="280" x2="520" y2="355"/>
    <line x1="510" y1="280" x2="465" y2="345"/>
    <line x1="440" y1="265" x2="375" y2="310"/>
    <line x1="400" y1="210" x2="320" y2="230"/>
    <line x1="400" y1="210" x2="325" y2="175"/>
    <line x1="440" y1="155" x2="370" y2="100"/>
    <line x1="440" y1="155" x2="430" y2="75"/>
  </g>
  <!-- Ring 2 nodes -->
  <g fill="#8b5cf6" opacity="0.7">
    <circle cx="480" cy="75" r="5"/>
    <circle cx="555" cy="78" r="5"/>
    <circle cx="645" cy="115" r="5"/>
    <circle cx="695" cy="185" r="5"/>
    <circle cx="700" cy="240" r="5"/>
    <circle cx="640" cy="320" r="5"/>
    <circle cx="520" cy="355" r="5"/>
    <circle cx="465" cy="345" r="5"/>
    <circle cx="375" cy="310" r="5"/>
    <circle cx="320" cy="230" r="5"/>
    <circle cx="325" cy="175" r="5"/>
    <circle cx="370" cy="100" r="5"/>
    <circle cx="430" cy="75" r="5"/>
  </g>
  <!-- Ring 1 nodes -->
  <g fill="#58a6ff" opacity="0.9">
    <circle cx="510" cy="140" r="7"/>
    <circle cx="580" cy="155" r="7"/>
    <circle cx="620" cy="210" r="7"/>
    <circle cx="580" cy="265" r="7"/>
    <circle cx="510" cy="280" r="7"/>
    <circle cx="440" cy="265" r="7"/>
    <circle cx="400" cy="210" r="7"/>
    <circle cx="440" cy="155" r="7"/>
  </g>
  <!-- Center glow -->
  <circle cx="510" cy="210" r="40" fill="url(#glow)" opacity="0.5"/>
  <!-- Center node -->
  <circle cx="510" cy="210" r="22" fill="#0d1117" stroke="#58a6ff" stroke-width="2.5"/>
  <circle cx="510" cy="210" r="18" fill="#1a2d4a"/>
  <text x="510" y="205" text-anchor="middle" fill="#58a6ff" font-family="monospace" font-size="8" font-weight="bold">Opus</text>
  <text x="510" y="218" text-anchor="middle" fill="#58a6ff" font-family="monospace" font-size="8" font-weight="bold">4.8</text>
  <!-- x1000 badge -->
  <rect x="855" y="30" width="120" height="36" rx="8" fill="#0d1117" stroke="#58a6ff" stroke-width="1.5"/>
  <text x="915" y="53" text-anchor="middle" fill="white" font-family="monospace" font-size="18" font-weight="bold">×1,000</text>
  <!-- Title text -->
  <text x="510" y="420" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="28" font-weight="600" letter-spacing="0.5">Dynamic Workflows</text>
  <!-- Status pills -->
  <rect x="330" y="448" width="150" height="32" rx="16" fill="#0d1117" stroke="#58a6ff" stroke-width="1.5"/>
  <circle cx="354" cy="464" r="6" fill="#58a6ff" opacity="0.8"/>
  <text x="380" y="469" fill="#58a6ff" font-family="Arial, sans-serif" font-size="13" font-weight="500">Dynamic Mode</text>
  <rect x="510" y="448" width="150" height="32" rx="16" fill="#0d1117" stroke="#f59e0b" stroke-width="1.5"/>
  <circle cx="534" cy="464" r="6" fill="#f59e0b" opacity="0.8"/>
  <text x="558" y="469" fill="#f59e0b" font-family="Arial, sans-serif" font-size="13" font-weight="500">Fast Mode</text>
</svg>
